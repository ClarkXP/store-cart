<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="cl.clarkxp.store.presentation.home.HomeFragment"
        android:label="store Challenge"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_show_product_detail"
            app:destination="@+id/productDetailFragment" />

        <action
            android:id="@+id/action_open_cart"
            app:destination="@id/cartFragment" />
    </fragment>

    <dialog
        android:id="@+id/productDetailFragment"
        android:name="cl.clarkxp.store.presentation.detail.ProductDetailFragment"
        android:label="Product Detail"
        tools:layout="@layout/fragment_product_detail">

        <argument
            android:name="productId"
            app:argType="integer" />
    </dialog>

    <fragment
        android:id="@+id/cartFragment"
        android:name="cl.clarkxp.store.presentation.cart.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart" />

</navigation>